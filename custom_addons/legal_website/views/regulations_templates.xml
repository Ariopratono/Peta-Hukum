<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Regulations List Template -->
        <template id="regulations_list_template" name="Regulations List">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="container my-5">
                        <!-- Header -->
                        <div class="text-center mb-4">
                            <h1 class="display-6 fw-bold text-uppercase">Peraturan Hukum Indonesia</h1>
                            <p class="text-muted">Akses mudah ke ribuan peraturan hukum Indonesia yang selalu up-to-date</p>
                        </div>
                        
                        <!-- Filter & Search Section -->
                        <div class="card mb-4">
                            <div class="card-header bg-white">
                                <a class="text-decoration-none text-dark fw-bold" data-bs-toggle="collapse" href="#filterCollapse" role="button" aria-expanded="false">
                                    <i class="fa fa-filter me-2"></i>FILTER &amp; PENCARIAN
                                </a>
                            </div>
                            <div class="collapse show" id="filterCollapse">
                                <div class="card-body">
                                    <form action="/regulations" method="get">
                                        <div class="row g-3">
                                            <!-- Kata Kunci -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Kata Kunci</label>
                                                <input type="text" name="search" class="form-control" t-att-value="search" placeholder="Cari peraturan..."/>
                                            </div>
                                            
                                            <!-- Bidang Hukum -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Bidang Hukum</label>
                                                <select name="bidang" class="form-select">
                                                    <option value="">Semua Bidang</option>
                                                    <t t-foreach="bidang_options" t-as="bidang">
                                                        <option t-att-value="bidang[0]" t-att-selected="'selected' if selected_bidang == bidang[0] else None">
                                                            <t t-esc="bidang[1]"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                            
                                            <!-- Tipe Dokumen -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Tipe Dokumen</label>
                                                <select name="tipe" class="form-select">
                                                    <option value="">Semua Tipe</option>
                                                    <t t-foreach="tipe_options" t-as="tipe">
                                                        <option t-att-value="tipe[0]" t-att-selected="'selected' if selected_tipe == tipe[0] else None">
                                                            <t t-esc="tipe[1]"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                            
                                            <!-- Tahun -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Tahun</label>
                                                <select name="tahun" class="form-select">
                                                    <option value="">Semua Tahun</option>
                                                    <t t-foreach="year_options" t-as="year">
                                                        <option t-att-value="year" t-att-selected="'selected' if int(selected_tahun or 0) == year else None">
                                                            <t t-esc="year"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                            
                                            <!-- Status -->
                                            <div class="col-md-4">
                                                <label class="form-label small">Status</label>
                                                <select name="status" class="form-select">
                                                    <option value="">Semua Status</option>
                                                    <option value="berlaku" t-att-selected="'selected' if selected_status == 'berlaku' else None">Berlaku</option>
                                                    <option value="dicabut" t-att-selected="'selected' if selected_status == 'dicabut' else None">Dicabut</option>
                                                    <option value="diubah" t-att-selected="'selected' if selected_status == 'diubah' else None">Diubah</option>
                                                    <option value="tidak_berlaku" t-att-selected="'selected' if selected_status == 'tidak_berlaku' else None">Tidak Berlaku</option>
                                                </select>
                                            </div>
                                            
                                            <!-- Buttons -->
                                            <div class="col-md-4 d-flex align-items-end gap-2">
                                                <button type="submit" class="btn btn-info text-white flex-grow-1">
                                                    <i class="fa fa-search me-1"></i>Cari
                                                </button>
                                                <a href="/regulations" class="btn btn-warning flex-grow-1">
                                                    <i class="fa fa-refresh me-1"></i>Reset
                                                </a>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Result Count -->
                        <div class="mb-3">
                            <p class="text-muted">
                                Menampilkan <strong><t t-esc="total_count"/></strong> peraturan hukum dengan kata kunci "<strong><t t-esc="search or '-'"/></strong>"
                            </p>
                        </div>
                        
                        <!-- Regulations List -->
                        <div class="regulations-list">
                            <t t-foreach="regulations" t-as="regulation">
                                <div class="card mb-3 border-start border-info border-4 shadow-sm">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-10">
                                                <h5 class="card-title text-primary mb-2">
                                                    <a t-attf-href="/regulations/#{regulation.id}" class="text-decoration-none">
                                                        <t t-esc="regulation.judul"/>
                                                    </a>
                                                </h5>
                                                <p class="mb-2">
                                                    <strong>
                                                        <t t-esc="regulation.bentuk_singkat"/> No. <t t-esc="regulation.nomor"/> Tahun <t t-esc="regulation.tahun"/>
                                                    </strong>
                                                </p>
                                                <div class="mb-2">
                                                    <span t-attf-class="badge bg-#{regulation.status == 'berlaku' and 'success' or regulation.status == 'dicabut' and 'danger' or 'warning'} me-2">
                                                        <t t-esc="dict(regulation._fields['status'].selection).get(regulation.status, regulation.status).upper()"/>
                                                    </span>
                                                    <span class="badge bg-info me-2">
                                                        <t t-esc="dict(regulation._fields['tipe_dokumen'].selection).get(regulation.tipe_dokumen, regulation.tipe_dokumen)"/>
                                                    </span>
                                                </div>
                                                <p class="small text-muted mb-0">
                                                    <strong>Subjek:</strong> <t t-esc="regulation.subjek or '-'"/>
                                                </p>
                                                <p class="small text-muted mb-0">
                                                    <strong>Sumber:</strong> <t t-esc="regulation.sumber or '-'"/>
                                                </p>
                                                
                                                <!-- Pasal Match Results -->
                                                <t t-set="match_list" t-value="pasal_matches and pasal_matches.get(regulation.id) or []"/>
                                                <t t-if="search and match_list">
                                                    <div class="mt-3 border-top pt-2">
                                                        <p class="mb-2 fw-bold text-success small">
                                                            <i class="fa fa-search me-1"/>
                                                            Ditemukan di <t t-esc="len(match_list)"/> bagian dokumen:
                                                        </p>
                                                        <t t-foreach="match_list" t-as="match">
                                                            <div class="mb-2 ms-2 p-2 rounded" style="background: #f8f9fa; border-left: 3px solid #0d6efd;">
                                                                <div class="d-flex align-items-center flex-wrap mb-1">
                                                                    <t t-if="match.get('bab')">
                                                                        <span class="badge bg-dark me-2 mb-1" style="font-size: 0.7rem;">
                                                                            <t t-esc="match.get('bab')"/>
                                                                        </span>
                                                                    </t>
                                                                    <span class="badge bg-primary me-2 mb-1" style="font-size: 0.7rem;">
                                                                        <t t-esc="match.get('display')"/>
                                                                    </span>
                                                                </div>
                                                                <t t-if="match.get('snippet')">
                                                                    <p class="mb-0 small text-muted" style="line-height: 1.5;">
                                                                        <t t-out="match.get('snippet')"/>
                                                                    </p>
                                                                </t>
                                                            </div>
                                                        </t>
                                                    </div>
                                                </t>
                                            </div>
                                            <div class="col-md-2 d-flex align-items-center justify-content-end">
                                                <a t-attf-href="/regulations/#{regulation.id}" class="btn btn-outline-primary btn-sm">
                                                    <i class="fa fa-eye me-1"/>Lihat Detail
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        
                        <!-- Pagination -->
                        <t t-if="total_pages > 1">
                            <nav aria-label="Page navigation" class="mt-4">
                                <ul class="pagination justify-content-center">
                                    <t t-if="current_page > 1">
                                        <li class="page-item">
                                            <a t-attf-href="/regulations?page=#{current_page - 1}&amp;search=#{search}&amp;bidang=#{selected_bidang}&amp;tipe=#{selected_tipe}&amp;tahun=#{selected_tahun}&amp;status=#{selected_status}" 
                                               class="page-link">
                                                <i class="fa fa-chevron-left"></i>
                                            </a>
                                        </li>
                                    </t>
                                    
                                    <t t-foreach="range(max(1, current_page - 2), min(total_pages + 1, current_page + 3))" t-as="page_num">
                                        <li t-attf-class="page-item #{current_page == page_num and 'active' or ''}">
                                            <a t-attf-href="/regulations?page=#{page_num}&amp;search=#{search}&amp;bidang=#{selected_bidang}&amp;tipe=#{selected_tipe}&amp;tahun=#{selected_tahun}&amp;status=#{selected_status}" 
                                               class="page-link" t-esc="page_num"/>
                                        </li>
                                    </t>
                                    
                                    <t t-if="current_page &lt; total_pages">
                                        <li class="page-item">
                                            <a t-attf-href="/regulations?page=#{current_page + 1}&amp;search=#{search}&amp;bidang=#{selected_bidang}&amp;tipe=#{selected_tipe}&amp;tahun=#{selected_tahun}&amp;status=#{selected_status}" 
                                               class="page-link">
                                                <i class="fa fa-chevron-right"></i>
                                            </a>
                                        </li>
                                    </t>
                                </ul>
                            </nav>
                        </t>
                        
                        <!-- Social Share -->
                        <div class="text-center mt-4">
                            <a href="#" class="btn btn-outline-primary btn-sm rounded-circle me-2"><i class="fa fa-facebook"></i></a>
                            <a href="#" class="btn btn-outline-info btn-sm rounded-circle me-2"><i class="fa fa-twitter"></i></a>
                            <a href="#" class="btn btn-outline-primary btn-sm rounded-circle"><i class="fa fa-linkedin"></i></a>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Regulation Detail Template -->
        <template id="regulation_detail_template" name="Detail Peraturan Hukum">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">
                    <div class="container-fluid px-4 mt-3">
                        <!-- Kembali ke Daftar - Top Left -->
                        <div class="mb-3">
                            <a href="/regulations" class="btn btn-outline-dark btn-sm">
                                <i class="fa fa-arrow-left"></i> Kembali ke Daftar
                            </a>
                        </div>

                        <!-- Breadcrumb -->
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                <li class="breadcrumb-item"><a href="/regulations">Peraturan Hukum</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Detail</li>
                            </ol>
                        </nav>

                        <!-- JUDUL UTAMA DI ATAS -->
                        <div class="text-center mb-4 py-4" style="background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); border-radius: 10px;">
                            <h1 class="text-white fw-bold mb-2" style="font-size: 1.8rem;">
                                <t t-esc="regulation.judul"/>
                            </h1>
                            <p class="text-white-50 mb-0">
                                <t t-esc="regulation.bentuk_singkat"/> Nomor <t t-esc="regulation.nomor"/> Tahun <t t-esc="regulation.tahun"/>
                            </p>
                            <div class="mt-2">
                                <t t-if="regulation.status == 'berlaku'">
                                    <span class="badge bg-success px-3 py-2">✓ BERLAKU</span>
                                </t>
                                <t t-elif="regulation.status == 'dicabut'">
                                    <span class="badge bg-danger px-3 py-2">✗ DICABUT</span>
                                </t>
                                <t t-elif="regulation.status == 'tidak_berlaku'">
                                    <span class="badge bg-warning text-dark px-3 py-2">⚠ TIDAK BERLAKU</span>
                                </t>
                                <t t-else="">
                                    <span class="badge bg-secondary px-3 py-2">? UNKNOWN</span>
                                </t>
                            </div>
                        </div>

                        <!-- MAIN 3-COLUMN LAYOUT -->
                        <div class="row">
                            <!-- LEFT SIDEBAR: Table of Contents -->
                            <div class="col-lg-2">
                                <div class="card sticky-top" style="top: 80px; max-height: calc(100vh - 100px); overflow-y: auto;">
                                    <div class="card-header bg-dark text-white py-2">
                                        <h6 class="mb-0"><i class="fa fa-list-ul"></i> Daftar Isi</h6>
                                    </div>
                                    <div class="card-body p-2" id="toc-container">
                                        <nav id="toc-nav" class="nav flex-column toc-nav">                                        
                                            <!-- Dynamic BAB items will be generated by JS -->
                                            <div id="toc-bab-container" class="toc-bab-container"></div>
                                        </nav>
                                    </div>
                                </div>
                            </div>

                            <!-- Mobile Table of Contents Trigger & Offcanvas Drawer -->
                            <div class="d-lg-none position-fixed mobile-toc-fab-container" style="bottom: 25px; right: 25px; z-index: 1040;">
                                <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center mobile-toc-fab" 
                                        type="button" 
                                        data-bs-toggle="offcanvas" 
                                        data-bs-target="#offcanvasToc" 
                                        aria-controls="offcanvasToc"
                                        style="width: 56px; height: 56px; background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); border: none;">
                                    <i class="fa fa-list-ul fa-lg text-white"></i>
                                </button>
                            </div>

                            <div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="offcanvasToc" aria-labelledby="offcanvasTocLabel" style="width: 290px; z-index: 1050;">
                                <div class="offcanvas-header bg-dark text-white py-3">
                                    <h5 class="offcanvas-title" id="offcanvasTocLabel"><i class="fa fa-list-ul"></i> Daftar Isi</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                                </div>
                                <div class="offcanvas-body p-2" id="toc-container-mobile" style="overflow-y: auto;">
                                    <nav id="toc-nav-mobile" class="nav flex-column toc-nav">
                                        <div id="toc-bab-container-mobile" class="toc-bab-container"></div>
                                    </nav>
                                </div>
                            </div>
                            
                            <!-- CENTER: Isi Peraturan -->
                            <div class="col-lg-7">
                                <!-- Tab untuk Perubahan (jika ada) -->
                                <t t-if="has_perubahan">
                                    <ul class="nav nav-tabs mb-3" id="regulationTabs" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active" id="induk-tab" data-bs-toggle="tab" 
                                                    data-bs-target="#induk-content" type="button" role="tab">
                                                <i class="fa fa-file-text"></i> UU Induk
                                            </button>
                                        </li>
                                        <t t-foreach="perubahan_list" t-as="perubahan">
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link" t-att-id="'perubahan-tab-' + str(perubahan_index)"
                                                        data-bs-toggle="tab" 
                                                        t-att-data-bs-target="'#perubahan-content-' + str(perubahan_index)" 
                                                        type="button" role="tab">
                                                    <i class="fa fa-edit"></i> 
                                                    <t t-esc="perubahan.get('nama', 'Perubahan')"/>
                                                </button>
                                            </li>
                                        </t>
                                        <li class="nav-item" role="presentation" t-if="konsolidasi_html">
                                            <button class="nav-link" id="konsolidasi-tab" data-bs-toggle="tab" 
                                                    data-bs-target="#konsolidasi-content" type="button" role="tab">
                                                <i class="fa fa-compress"></i> Konsolidasi
                                            </button>
                                        </li>
                                    </ul>
                                    
                                    <!-- Tab Content -->
                                    <div class="tab-content" id="regulationTabsContent">
                                        <!-- Tab UU Induk -->
                                        <div class="tab-pane fade show active" id="induk-content" role="tabpanel">
                                            <div class="card">
                                                <div class="card-body regulation-content-main" id="regulation-content-scroll" 
                                                     style="max-height: calc(100vh - 250px); overflow-y: auto; line-height: 1.8;">
                                                    <t t-if="regulation.isi_peraturan">
                                                        <div id="section-batang-tubuh" class="content-section">
                                                            <t t-raw="regulation.isi_peraturan"/>
                                                        </div>
                                                    </t>
                                                    <t t-else="">
                                                        <p class="text-muted text-center py-5">Isi peraturan tidak tersedia.</p>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Tab Perubahan -->
                                        <t t-foreach="perubahan_list" t-as="perubahan">
                                            <div class="tab-pane fade" t-att-id="'perubahan-content-' + str(perubahan_index)" role="tabpanel">
                                                <div class="card">
                                                    <div class="card-body regulation-content-main" 
                                                         style="max-height: calc(100vh - 250px); overflow-y: auto; line-height: 1.8;">
                                                        <t t-if="perubahan.get('isi_html')">
                                                            <t t-raw="perubahan.get('isi_html')"/>
                                                        </t>
                                                        <t t-elif="perubahan.get('isi_txt')">
                                                            <pre style="white-space: pre-wrap; font-family: inherit;"><t t-esc="perubahan.get('isi_txt')"/></pre>
                                                        </t>
                                                        <t t-else="">
                                                            <p class="text-muted text-center py-5">Isi perubahan tidak tersedia.</p>
                                                        </t>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        
                                        <!-- Tab Konsolidasi -->
                                        <div class="tab-pane fade" id="konsolidasi-content" role="tabpanel" t-if="konsolidasi_html">
                                            <div class="card">
                                                <div class="card-body regulation-content-main" 
                                                     style="max-height: calc(100vh - 250px); overflow-y: auto; line-height: 1.8;">
                                                    <t t-raw="konsolidasi_html"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                                
                                <!-- Tampilan Normal (tanpa perubahan) -->
                                <t t-if="not has_perubahan">
                                    <div class="card">
                                        <div class="card-body regulation-content-main" id="regulation-content-scroll" 
                                             style="max-height: calc(100vh - 200px); overflow-y: auto; line-height: 1.8;">
                                            <t t-if="regulation.isi_peraturan">
                                                <div id="section-batang-tubuh" class="content-section">
                                                    <t t-raw="regulation.isi_peraturan"/>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <p class="text-muted text-center py-5">Isi peraturan tidak tersedia.</p>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                                
                                <!-- Control Buttons -->
                                <div class="mt-2 d-flex justify-content-between">
                                    <div>
                                        <button class="btn btn-sm btn-outline-secondary" onclick="adjustFontSize(-1)">
                                            <i class="fa fa-minus"></i> A
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary ms-1" onclick="adjustFontSize(1)">
                                            <i class="fa fa-plus"></i> A
                                        </button>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-outline-primary" onclick="toggleFullscreen()">
                                            <i class="fa fa-expand"></i> Layar Penuh
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- RIGHT SIDEBAR: Info & Klasifikasi -->
                            <div class="col-lg-3">
                                <!-- Informasi Dasar -->
                                <div class="card mb-3">
                                    <div class="card-header bg-primary text-white py-2">
                                        <h6 class="mb-0"><i class="fa fa-info-circle"></i> Informasi Dasar</h6>
                                    </div>
                                    <div class="card-body p-3">
                                        <table class="table table-sm table-borderless mb-0" style="font-size: 0.85rem;">
                                            <tr>
                                                <td class="text-muted" style="width: 40%;">Bentuk</td>
                                                <td><strong><t t-esc="regulation.bentuk or '-'"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Nomor</td>
                                                <td><strong><t t-esc="regulation.nomor"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Tahun</td>
                                                <td><strong><t t-esc="regulation.tahun"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">T.E.U.</td>
                                                <td><t t-esc="regulation.teu or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Tempat Penetapan</td>
                                                <td><t t-esc="regulation.tempat_penetapan or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Tgl Penetapan</td>
                                                <td><t t-esc="regulation.tanggal_penetapan or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Tgl Pengundangan</td>
                                                <td><t t-esc="regulation.tanggal_pengundangan or '-'"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                                
                                <!-- Klasifikasi -->
                                <div class="card mb-3">
                                    <div class="card-header bg-info text-white py-2">
                                        <h6 class="mb-0"><i class="fa fa-tags"></i> Klasifikasi</h6>
                                    </div>
                                    <div class="card-body p-3">
                                        <table class="table table-sm table-borderless mb-0" style="font-size: 0.85rem;">
                                            <tr>
                                                <td class="text-muted" style="width: 40%;">Bidang Hukum</td>
                                                <td>
                                                    <span class="badge bg-secondary">
                                                        <t t-set="bidang_display" t-value="regulation.bidang"/>
                                                        <t t-if="bidang_display and str(bidang_display) not in ['True', 'False', '1', '0']">
                                                            <t t-esc="str(bidang_display).replace('_', ' ').title()"/>
                                                        </t>
                                                        <t t-else="">-</t>
                                                    </span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Tipe Dokumen</td>
                                                <td>
                                                    <t t-set="tipe_display" t-value="regulation.tipe_dokumen"/>
                                                    <t t-if="tipe_display and str(tipe_display) not in ['True', 'False', '1', '0']">
                                                        <t t-esc="str(tipe_display).replace('_', ' ').title()"/>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Sumber</td>
                                                <td><t t-esc="regulation.sumber or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Bahasa</td>
                                                <td><t t-esc="regulation.bahasa or '-'"/></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">Lokasi</td>
                                                <td><t t-esc="regulation.lokasi or '-'"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                                
                                <!-- Subjek (jika ada) -->
                                <div class="card mb-3" t-if="regulation.subjek">
                                    <div class="card-header bg-secondary text-white py-2">
                                        <h6 class="mb-0"><i class="fa fa-bookmark"></i> Subjek</h6>
                                    </div>
                                    <div class="card-body p-3">
                                        <p class="mb-0 small"><t t-esc="regulation.subjek"/></p>
                                    </div>
                                </div>
                                
                                <!-- Kata Kunci -->
                                <div class="card mb-3" t-if="regulation.kata_kunci">
                                    <div class="card-header bg-warning py-2">
                                        <h6 class="mb-0"><i class="fa fa-key"></i> Kata Kunci</h6>
                                    </div>
                                    <div class="card-body p-3">
                                        <t t-set="keywords" t-value="regulation.kata_kunci.split(',')"/>
                                        <t t-foreach="keywords" t-as="keyword">
                                            <span class="badge bg-light text-dark border me-1 mb-1"><t t-esc="keyword.strip()"/></span>
                                        </t>
                                    </div>
                                </div>
                                
                                <!-- Download & Links - DINONAKTIFKAN -->
                                <div class="card mb-3">
                                    <div class="card-header bg-success text-white py-2">
                                        <h6 class="mb-0"><i class="fa fa-download"></i> Unduh Dokumen</h6>
                                    </div>
                                    <div class="card-body p-3">
                                        <div class="d-grid gap-2">
                                            <t t-if="regulation.file_pdf">
                                                <a t-attf-href="/web/content?model=legal.regulation&amp;id=#{regulation.id}&amp;field=file_pdf&amp;filename_field=file_name&amp;download=true" 
                                                   class="btn btn-danger btn-sm" target="_blank">
                                                    <i class="fa fa-file-pdf-o"></i> Download PDF
                                                </a>
                                            </t>
                                            <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                                                <i class="fa fa-print"></i> Cetak
                                            </button>
                                            <button class="btn btn-outline-primary btn-sm" onclick="shareRegulation()">
                                                <i class="fa fa-share-alt"></i> Bagikan
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                
                                <!-- AKSI CEPAT - DI-COMMENT DAHULU -->
                                <div class="card mb-3">
                                    <div class="card-header">
                                        <h6 class="mb-0"><i class="fa fa-bolt"></i> Aksi Cepat</h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-grid gap-2">
                                            <a href="/regulations" class="btn btn-outline-secondary btn-sm">
                                                <i class="fa fa-arrow-left"></i> Kembali ke Daftar
                                            </a>
                                        </div>
                                    </div>
                                </div>
                               
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Empty Regulations Template (when model not available) -->
        <template id="regulations_empty_template" name="Regulations Empty">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="container my-5 text-center">
                        <h2>Modul Peraturan Hukum Tidak Tersedia</h2>
                        <p class="text-muted">Silakan hubungi administrator.</p>
                    </div>
                </div>
            </t>
        </template>
        
    </data>
</odoo>
