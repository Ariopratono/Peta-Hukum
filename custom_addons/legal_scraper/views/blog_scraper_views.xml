<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_legal_blog_scraper_form" model="ir.ui.view">
            <field name="name">legal.blog.scraper.form</field>
            <field name="model">legal.blog.scraper</field>
            <field name="arch" type="xml">
                <form string="Blog Scraper Configuration">
                    <header>
                        <button name="action_scrape_blog" string="Scrape Now" type="object" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Scraper Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="rss_url"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <field name="last_run" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="view_legal_blog_scraper_list" model="ir.ui.view">
            <field name="name">legal.blog.scraper.list</field>
            <field name="model">legal.blog.scraper</field>
            <field name="arch" type="xml">
                <list string="Blog Scrapers">
                    <field name="name"/>
                    <field name="rss_url"/>
                    <field name="active"/>
                    <field name="last_run"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_legal_blog_scraper" model="ir.actions.act_window">
            <field name="name">Blog Scrapers</field>
            <field name="res_model">legal.blog.scraper</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Submenu Item -->
        <menuitem id="menu_legal_blog_scraper"
                  name="Blog Scraper"
                  parent="legal_scraper.menu_legal_scraper"
                  action="action_legal_blog_scraper"
                  sequence="20"/>
    </data>
</odoo>
